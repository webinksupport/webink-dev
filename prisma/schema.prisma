generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Auth ────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  phone            String?
  password         String?  // bcrypt hash
  role             Role     @default(CUSTOMER)
  stripeCustomerId String?  @unique
  emailVerified    Boolean  @default(false)
  suspended        Boolean  @default(false)
  notes            String?  @db.Text // internal admin notes
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions Subscription[]
  orders        Order[]
  sessions      Session[]
  accounts      Account[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─── Products ────────────────────────────────────────────────────────

model Product {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  description      String        @db.Text
  shortDescription String?       @db.Text
  category         String        // e.g. "hosting", "seo", "social", "video", "other"
  type             ProductType
  status           ProductStatus @default(ACTIVE)
  active           Boolean       @default(true)
  featured         Boolean       @default(false)
  setupFee         Int?          // cents — optional one-time setup fee
  billingInterval  String?       // "month" | "year" | null for one-time
  trialDays        Int?
  sortOrder        Int           @default(0)
  stripeProductId  String?       // Stripe Product ID
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  variants ProductVariant[]

  @@index([slug])
  @@index([category])
}

enum ProductType {
  SIMPLE
  SUBSCRIPTION
  VARIABLE
  VARIABLE_SUBSCRIPTION
  ONE_TIME // kept for backward compat with existing data
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DRAFT
}

model ProductVariant {
  id              String          @id @default(cuid())
  productId       String
  name            String          // e.g. "Starter", "Basic", "Pro"
  priceMonthly    Int?            // cents — e.g. 3100 = $31.00
  priceAnnual     Int?            // cents — annual billing option
  priceOneTime    Int?            // cents — for one-time products
  salePrice       Int?            // cents — promotional price (null = no sale)
  setupFee        Int?            // cents — optional one-time setup fee for this variant
  billingInterval BillingInterval @default(MONTHLY)
  trialDays       Int?
  stripePriceId   String?         // Stripe Price ID for this variant
  stripeProductId String?         // Stripe Product ID
  contactOnly     Boolean         @default(false) // true = "Contact for Pricing"
  active          Boolean         @default(true)
  status          VariantStatus   @default(ACTIVE)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  orderItems    OrderItem[]

  @@index([productId])
  @@index([stripePriceId])
}

enum VariantStatus {
  ACTIVE
  INACTIVE
}

enum BillingInterval {
  MONTHLY
  ANNUAL
  ONE_TIME
}

// ─── Subscriptions ───────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  variantId            String
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(PENDING)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user    User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant     @relation(fields: [variantId], references: [id])
  notes   SubscriptionNote[]

  @@index([userId])
  @@index([stripeSubscriptionId])
}

// ─── Subscription Notes (Activity Log) ───────────────────────────────

model SubscriptionNote {
  id             String               @id @default(cuid())
  subscriptionId String
  type           SubscriptionNoteType
  message        String               @db.Text
  metadata       Json?
  createdAt      DateTime             @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
  @@index([createdAt])
}

enum SubscriptionNoteType {
  CREATED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  PAYMENT_RETRY
  UPGRADED
  DOWNGRADED
  CANCELLED
  REACTIVATED
  INTERVAL_CHANGED
  STATUS_CHANGED
  ADMIN_NOTE
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

// ─── Orders ──────────────────────────────────────────────────────────

model Order {
  id                String      @id @default(cuid())
  userId            String
  stripeSessionId   String?     @unique
  stripePaymentId   String?
  status            OrderStatus @default(PENDING)
  totalAmount       Int         // cents
  currency          String      @default("usd")
  qboInvoiceId      String?     // QuickBooks invoice ID after sync
  qboExpenseId      String?     // QBO expense entry for Stripe fee
  stripeFeeAmount   Int?        // cents — Stripe processing fee
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([userId])
  @@index([stripeSessionId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int    @default(1)
  unitPrice Int    // cents — price at time of purchase
  total     Int    // cents

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── Pages (CMS Page Manager) ───────────────────────────────────────

model Page {
  id        String     @id @default(cuid())
  title     String
  slug      String     @unique       // URL slug, e.g. "my-new-page"
  status    PageStatus @default(DRAFT)
  isCore    Boolean    @default(false) // true for /, /about, /contact, /services — cannot be deleted
  template  String     @default("generic") // template type
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([slug])
  @@index([status])
}

enum PageStatus {
  PUBLISHED
  DRAFT
}

// ─── CMS Content ────────────────────────────────────────────────────

model PageContent {
  id        String           @id @default(cuid())
  pageSlug  String           // e.g. 'home', 'about', 'services/seo'
  blockKey  String           // e.g. 'hero_headline', 'hero_subtext', 'hero_image'
  blockType ContentBlockType
  value     String           @db.LongText
  jsonValue Json?            // structured data: arrays, objects (photos, features, FAQs, etc.)
  updatedAt DateTime         @updatedAt

  @@unique([pageSlug, blockKey])
  @@index([pageSlug])
}

enum ContentBlockType {
  TEXT
  HTML
  IMAGE
  LINK
  BUTTON
  SEO
  JSON
}

// ─── Media ────────────────────────────────────────────────────────

model MediaItem {
  id        String   @id @default(cuid())
  filename  String
  filepath  String   @unique
  altText   String?
  mimeType  String
  size      Int
  width     Int?
  height    Int?
  createdAt DateTime @default(now())
}

// ─── Settings ──────────────────────────────────────────────────────

model Setting {
  key       String   @id
  value     String   @db.Text // encrypted for secrets
  isSecret  Boolean  @default(false)
  updatedAt DateTime @updatedAt
}

// ─── Menu ─────────────────────────────────────────────────────────────

model MenuItem {
  id        String     @id @default(cuid())
  label     String
  url       String
  order     Int        @default(0)
  parentId  String?
  parent    MenuItem?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuTree")
  menuSlug  String     @default("primary")
  updatedAt DateTime   @updatedAt

  @@index([menuSlug])
  @@index([parentId])
}

// --- Social Media Studio ----------------------------------------------------

model SocialPost {
  id           String           @id @default(cuid())
  title        String?
  caption      String?          @db.Text
  hashtags     String?          @db.Text
  mediaPath    String?          // path to image/video
  mediaType    String?          // "image" | "video"
  platforms    String?          // JSON array: ["facebook","instagram","linkedin"]
  status       SocialPostStatus @default(DRAFT)
  scheduledAt  DateTime?
  publishedAt  DateTime?
  fbPostId     String?          // Facebook post ID after publish
  igPostId     String?          // Instagram post ID after publish
  liPostId     String?          // LinkedIn post ID after publish
  fbLikes      Int?
  fbComments   Int?
  fbReach      Int?
  igLikes      Int?
  igComments   Int?
  igReach      Int?
  postType       String           @default("FEED") // FEED | CAROUSEL | REEL
  carouselSlides Json?            // JSON array of slide objects for carousel posts
  originalPostId String?          // self-reference for recycled posts
  abVariant      String?          // "A" or "B" for AB tests
  abGroupId      String?          // shared cuid linking AB variants
  notes          String?          @db.Text
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  @@index([status])
  @@index([scheduledAt])
}

enum SocialPostStatus {
  DRAFT
  PENDING_REVIEW
  SCHEDULED
  PUBLISHING
  PUBLISHED
  FAILED
}

model SocialIdea {
  id          String   @id @default(cuid())
  topic       String
  hook        String   @db.Text
  caption     String   @db.Text
  hashtags    String?  @db.Text
  brandVoice  String?
  used        Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model SocialHashtagSet {
  id        String   @id @default(cuid())
  name      String
  hashtags  String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SocialBrandProfile {
  id                String   @id @default(cuid())
  businessName      String
  tagline           String?
  brandVoice        String?  // Professional, Casual, Witty, Inspirational, Bold
  primaryColors     Json?    // Array of hex color strings
  targetAudience    String?  @db.Text
  keyServices       String?  @db.Text
  brandKeywords     String?  @db.Text
  competitorHandles String?  @db.Text
  logoPath          String?
  updatedAt         DateTime @updatedAt
}

model SocialContentPillar {
  id          String   @id @default(cuid())
  title       String
  description String?  @db.Text
  icon        String?
  color       String?
  createdAt   DateTime @default(now())
}

model SocialCompetitor {
  id          String   @id @default(cuid())
  handle      String
  displayName String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
}

model SocialClient {
  id              String   @id @default(cuid())
  name            String
  instagramHandle String?
  facebookPageId  String?
  accessToken     String?  @db.Text
  brandProfileId  String?
  userId          String?
  status          String   @default("ACTIVE")
  createdAt       DateTime @default(now())
}

model SocialStory {
  id          String    @id @default(cuid())
  title       String
  slides      Json
  scheduledAt DateTime?
  publishedAt DateTime?
  status      String    @default("DRAFT")
  igStoryId   String?
  createdAt   DateTime  @default(now())
}
