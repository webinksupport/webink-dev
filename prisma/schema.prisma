generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

// ─── Auth ────────────────────────────────────────────────────────────

model User {
  id               String   @id @default(cuid())
  email            String   @unique
  name             String?
  password         String?  // bcrypt hash
  role             Role     @default(CUSTOMER)
  stripeCustomerId String?  @unique
  emailVerified    Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  subscriptions Subscription[]
  orders        Order[]
  sessions      Session[]
  accounts      Account[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  CUSTOMER
  ADMIN
}

// ─── Products ────────────────────────────────────────────────────────

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String      @db.Text
  category    String      // e.g. "hosting", "seo", "social", "video", "other"
  type        ProductType
  active      Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  variants ProductVariant[]

  @@index([slug])
  @@index([category])
}

enum ProductType {
  ONE_TIME
  SUBSCRIPTION
}

model ProductVariant {
  id              String          @id @default(cuid())
  productId       String
  name            String          // e.g. "Starter", "Basic", "Pro"
  priceMonthly    Int?            // cents — e.g. 3100 = $31.00
  priceAnnual     Int?            // cents — annual billing option
  priceOneTime    Int?            // cents — for one-time products
  salePrice       Int?            // cents — promotional price (null = no sale)
  billingInterval BillingInterval @default(MONTHLY)
  stripePriceId   String?         // Stripe Price ID for this variant
  stripeProductId String?         // Stripe Product ID
  contactOnly     Boolean         @default(false) // true = "Contact for Pricing"
  active          Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  product       Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  subscriptions Subscription[]
  orderItems    OrderItem[]

  @@index([productId])
  @@index([stripePriceId])
}

enum BillingInterval {
  MONTHLY
  ANNUAL
  ONE_TIME
}

// ─── Subscriptions ───────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String
  variantId            String
  stripeSubscriptionId String?            @unique
  status               SubscriptionStatus @default(PENDING)
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  canceledAt           DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([userId])
  @@index([stripeSubscriptionId])
}

enum SubscriptionStatus {
  PENDING
  ACTIVE
  PAST_DUE
  CANCELED
  UNPAID
  PAUSED
}

// ─── Orders ──────────────────────────────────────────────────────────

model Order {
  id                String      @id @default(cuid())
  userId            String
  stripeSessionId   String?     @unique
  stripePaymentId   String?
  status            OrderStatus @default(PENDING)
  totalAmount       Int         // cents
  currency          String      @default("usd")
  qboInvoiceId      String?     // QuickBooks invoice ID after sync
  qboExpenseId      String?     // QBO expense entry for Stripe fee
  stripeFeeAmount   Int?        // cents — Stripe processing fee
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items OrderItem[]

  @@index([userId])
  @@index([stripeSessionId])
}

model OrderItem {
  id        String @id @default(cuid())
  orderId   String
  variantId String
  quantity  Int    @default(1)
  unitPrice Int    // cents — price at time of purchase
  total     Int    // cents

  order   Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id])

  @@index([orderId])
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// ─── CMS Content ────────────────────────────────────────────────────

model PageContent {
  id        String           @id @default(cuid())
  pageSlug  String           // e.g. 'home', 'about', 'services/seo'
  blockKey  String           // e.g. 'hero_headline', 'hero_subtext', 'hero_image'
  blockType ContentBlockType
  value     String           @db.LongText
  updatedAt DateTime         @updatedAt

  @@unique([pageSlug, blockKey])
  @@index([pageSlug])
}

enum ContentBlockType {
  TEXT
  HTML
  IMAGE
  LINK
}
